---
/*
  Playground sample — GlobalHeader global block component.
  Rendered by <GlobalBlock slug="header-cta" /> in Layout.astro.
*/

interface Props {
  siteTitle?: string;
  ctaLabel?: string;
}

const { siteTitle, ctaLabel } = Astro.props;
---

{siteTitle || ctaLabel ? (
  <div class="global-header-cta" style="background: var(--line, #e8e0d3); padding: 0.4rem 1.5rem; font-family: system-ui, sans-serif; font-size: 0.85rem; display: flex; align-items: center; gap: 1rem;">
    {siteTitle && <strong>{siteTitle}</strong>}
    {ctaLabel && <span>{ctaLabel}</span>}
  </div>
) : null}
