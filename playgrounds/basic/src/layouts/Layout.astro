---
import { getI18nMeta } from '@astroblocks/astro-blocks/getI18nMeta';
import { getLanguages } from '@astroblocks/astro-blocks/getLanguages';
import { getMenu } from '@astroblocks/astro-blocks/getMenu';

const {
  title = 'AstroBlocks Playground',
  description = '',
  canonical = '',
  noindex = false,
  i18n,
  site = {},
  seo = {},
} = Astro.props;

const { languages, defaultLocale } = await getLanguages();
const activeLocale = i18n?.locale || defaultLocale;
const i18nMeta = getI18nMeta(i18n, { baseUrl: site?.baseUrl });
const menu = await getMenu('main', { locale: activeLocale });
const robots = noindex ? (seo?.nofollow ? 'noindex, nofollow' : 'noindex') : seo?.nofollow ? 'index, nofollow' : null;

const languageLinks = languages.map((language) => ({
  ...language,
  href:
    i18n?.alternates?.find((entry) => entry.locale === language.code)?.path ||
    (language.code === defaultLocale ? '/' : `/${language.code}`),
  active: language.code === activeLocale,
}));
---

<!doctype html>
<html lang={i18nMeta?.htmlLang || activeLocale || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {robots && <meta name="robots" content={robots} />}
    {seo?.image && <meta property="og:image" content={seo.image} />}
    {i18nMeta?.alternates.map((entry) => (
      <link rel="alternate" hreflang={entry.hrefLang} href={entry.href} />
    ))}
    {i18nMeta?.ogLocale && <meta property="og:locale" content={i18nMeta.ogLocale} />}
    {i18nMeta?.ogLocaleAlternate.map((entry) => (
      <meta property="og:locale:alternate" content={entry} />
    ))}
    <style>
      :root {
        color-scheme: light;
        --surface: #f8f5ef;
        --paper: #ffffff;
        --ink: #1b120d;
        --muted: #6d5b4f;
        --line: #e8e0d3;
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: "Instrument Serif", Georgia, serif;
        background: radial-gradient(circle at top, #fffaf0 0%, var(--surface) 55%, #efe7d9 100%);
        color: var(--ink);
      }

      a { color: inherit; text-decoration: none; }
      header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(16px);
        background: rgba(248, 245, 239, 0.78);
        border-bottom: 1px solid var(--line);
      }

      .shell {
        width: min(100%, 72rem);
        margin: 0 auto;
        padding: 1rem 1.5rem;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .brand strong {
        font-size: 1.1rem;
      }

      .brand span {
        font-family: system-ui, sans-serif;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .links {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: system-ui, sans-serif;
        font-size: 0.95rem;
      }

      .locale-links {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin-left: 0.75rem;
        padding-left: 0.75rem;
        border-left: 1px solid var(--line);
      }

      .locale-link {
        font-size: 0.82rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .locale-link--active {
        color: var(--ink);
        font-weight: 600;
      }

      footer {
        padding: 3rem 1.5rem 4rem;
        color: var(--muted);
        font-family: system-ui, sans-serif;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="shell nav">
        <a href="/" class="brand">
          <strong>{site.siteName || 'AstroBlocks Playground'}</strong>
          <span>Consumer DX validation project</span>
        </a>
        <nav class="links">
          {menu.map((item) => <a href={item.path}>{item.name}</a>)}
          <a href="/cms">CMS</a>
          <span class="locale-links">
            {languageLinks.map((language) => (
              <a
                href={language.href}
                class:list={['locale-link', language.active && 'locale-link--active']}
                aria-current={language.active ? 'page' : undefined}
              >
                {language.code}
              </a>
            ))}
          </span>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="shell">
      Built to validate `@astroblocks/astro-blocks` as a consumer would install and use it.
    </footer>
  </body>
</html>
