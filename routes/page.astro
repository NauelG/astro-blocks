import { getPageBySlug, loadPages, loadSite } from '../api/data.js';
import { getCacheConfig, getPageCacheTags } from '../utils/cache.js';
import { resolvePageSeo } from '../utils/slug.js';
import { Layout, componentMap } from 'astro-blocks-runtime';
import BlockFallback from './BlockFallback.astro';

export const prerender = false;

const projectRoot = import.meta.env.ASTRO_BLOCKS_PROJECT_ROOT || process.cwd();
process.env.ASTRO_BLOCKS_PROJECT_ROOT = projectRoot;

const pagesData = await loadPages();
const site = await loadSite();
const page = getPageBySlug(pagesData, Astro.params.slug ?? '');
const cacheConfig = getCacheConfig();

if (page && cacheConfig.enabled && Astro.cache.enabled) {
  Astro.cache.set({
    maxAge: cacheConfig.maxAge,
    swr: cacheConfig.swr,
    tags: getPageCacheTags(page),
  });
} else {
  Astro.cache.set(false);
}

if (!page) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not Found';
}

const { title, description, canonical, noindex, seo } = page
  ? resolvePageSeo(site, page)
  : {
      title: 'Page not found',
      description: '',
      canonical: '',
      noindex: true,
      seo: {},
    };
const blocks = page?.blocks || [];
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  site={site}
  seo={seo}
>
  {!page && (
    <section>
      <h1>Page not found</h1>
      <p>The requested page is not available.</p>
    </section>
  )}
  {blocks.map((block) => {
    const Comp = componentMap[block.type];
    if (!Comp) {
      console.warn(`[astro-blocks] Unknown block type "${block.type}" – no component mapped.`);
      return import.meta.env.DEV ? <BlockFallback type={block.type} /> : null;
    }
    return <Comp {...(block.props || {})} />;
  })}
</Layout>
