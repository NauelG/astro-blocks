import { getDefaultLocale, getPageBySlugStrict, getPageLocaleViewStrict, getPageSlugStrict, getPageStatusStrict, loadLanguages, loadPages, loadRedirects, loadSite } from '../api/data.js';
import { getCacheConfig, getGlobalCacheTags, getPageCacheTags, getPathCacheTag } from '../utils/cache.js';
import { localizeBlockPropsForRender } from '../utils/block-props.js';
import { findRedirectByPath, normalizeRedirectPath } from '../utils/redirects.js';
import { buildLocalizedPath, resolveLocalizedSlug, resolvePageSeo, slugToPath } from '../utils/slug.js';
import { normalizeLocaleCode, resolveRootLocaleRedirect } from '../utils/localization.js';
import { Layout, componentMap, schemaMap as runtimeSchemaMap } from 'astro-blocks-runtime';
import BlockFallback from './BlockFallback.astro';

export const prerender = false;

const projectRoot = import.meta.env.ASTRO_BLOCKS_PROJECT_ROOT || process.cwd();
process.env.ASTRO_BLOCKS_PROJECT_ROOT = projectRoot;

const [pagesData, site, languagesData, redirectsData] = await Promise.all([loadPages(), loadSite(), loadLanguages(), loadRedirects()]);
const defaultLocale = getDefaultLocale(languagesData);
const enabledLocales = languagesData.languages.filter((language) => language.enabled !== false).map((language) => normalizeLocaleCode(language.code));
const enabledLocaleSet = new Set(enabledLocales);
const LOCALE_PREFERENCE_COOKIE = 'astroblocks-locale';
const LOCALE_PREFERENCE_MAX_AGE = 60 * 60 * 24 * 365;
function persistLocalePreference(localeCode: string): void {
  const normalizedLocale = normalizeLocaleCode(localeCode);
  if (!normalizedLocale || !enabledLocaleSet.has(normalizedLocale)) return;
  Astro.cookies.set(LOCALE_PREFERENCE_COOKIE, normalizedLocale, {
    path: '/',
    maxAge: LOCALE_PREFERENCE_MAX_AGE,
    sameSite: 'lax',
    httpOnly: true,
  });
}

const { locale, slug } = resolveLocalizedSlug(Astro.params.slug ?? '', enabledLocales, defaultLocale);
const requestUrl = new URL(Astro.request.url);
const rootRedirect = resolveRootLocaleRedirect({
  requestUrl,
  referer: Astro.request.headers.get('referer'),
  cookieLocale: Astro.cookies.get(LOCALE_PREFERENCE_COOKIE)?.value,
  acceptLanguage: Astro.request.headers.get('accept-language'),
  availableLocales: enabledLocales,
  defaultLocale,
  hasPublishedHome: (entryLocale) => Boolean(getPageBySlugStrict(pagesData, '/', entryLocale)),
});

if (rootRedirect) {
  const targetPath = slugToPath(buildLocalizedPath('/', rootRedirect.locale, defaultLocale));
  const targetUrl = `${targetPath}${requestUrl.search || ''}`;
  const response = Astro.redirect(targetUrl, 302);
  if (rootRedirect.source === 'accept-language') {
    response.headers.set('Vary', 'Accept-Language');
  }
  persistLocalePreference(rootRedirect.locale);
  return response;
}
const page = getPageBySlugStrict(pagesData, slug, locale);
const redirectMatch = !page ? findRedirectByPath(redirectsData.redirects || [], requestUrl.pathname) : null;
const cacheConfig = getCacheConfig();
const requestPath = normalizeRedirectPath(requestUrl.pathname || '/');

if (cacheConfig.enabled && Astro.cache.enabled) {
  if (page) {
    Astro.cache.set({
      maxAge: cacheConfig.maxAge,
      swr: cacheConfig.swr,
      tags: getPageCacheTags(page, locale, defaultLocale),
    });
  } else if (redirectMatch) {
    Astro.cache.set({
      maxAge: cacheConfig.maxAge,
      swr: cacheConfig.swr,
      tags: [...getGlobalCacheTags(), getPathCacheTag(requestPath)],
    });
  } else {
    Astro.cache.set(false);
  }
} else {
  Astro.cache.set(false);
}

persistLocalePreference(locale);

if (redirectMatch) {
  const targetUrl = `${redirectMatch.to}${requestUrl.search || ''}`;
  return Astro.redirect(targetUrl, redirectMatch.statusCode);
}

if (!page) {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not Found';
}

const localeKeys = new Set(enabledLocales.map((entry) => normalizeLocaleCode(entry)));
const view = page ? getPageLocaleViewStrict(page, locale) : null;
const localizedSlug = view ? buildLocalizedPath(view.slug, locale, defaultLocale) : '/';
const i18n = page
  ? {
      locale,
      defaultLocale,
      alternates: enabledLocales
        .filter((entryLocale) => getPageStatusStrict(page, entryLocale) === 'published')
        .map((entryLocale) => ({
          locale: entryLocale,
          path: slugToPath(buildLocalizedPath(getPageSlugStrict(page, entryLocale) || '/', entryLocale, defaultLocale)),
        })),
    }
  : undefined;
const localizedPage = view
  ? {
      ...view,
      slug: localizedSlug,
      blocks: (view.blocks || []).map((block) => ({
        type: block.type,
        props: localizeBlockPropsForRender(block.props || {}, block.type, runtimeSchemaMap, locale, defaultLocale, localeKeys),
      })),
    }
  : null;

const { title, description, canonical, noindex, seo } = localizedPage
  ? resolvePageSeo(site, localizedPage)
  : {
      title: 'Page not found',
      description: '',
      canonical: '',
      noindex: true,
      seo: {},
    };

const blocks = localizedPage?.blocks || [];
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  noindex={noindex}
  site={site}
  seo={seo}
  i18n={i18n}
>
  {!localizedPage && (
    <section>
      <h1>Page not found</h1>
      <p>The requested page is not available.</p>
    </section>
  )}
  {blocks.map((block) => {
    const Comp = componentMap[block.type];
    if (!Comp) {
      console.warn(`[astro-blocks] Unknown block type "${block.type}" – no component mapped.`);
      return import.meta.env.DEV ? <BlockFallback type={block.type} /> : null;
    }
    return <Comp {...(block.props || {})} />;
  })}
</Layout>
