---
/**
 * Modal de detalle reutilizable: creación o edición de una entidad.
 * Misma estructura y diseño que los formularios de la lista (cms-card, cms-form-actions).
 * Uso: incluir en la página de listado; abrir/cerrar con dialog.showModal() / dialog.close().
 * El título se puede actualizar por JS (ej. "Nueva página" / "Editar página").
 */
interface Props {
  id: string;
  title?: string;
}
const { id, title = '' } = Astro.props;
const titleId = id + '-title';
---

<dialog id={id} class="cms-detail-modal" aria-labelledby={titleId}>
  <div class="cms-detail-modal-panel" role="document">
    <h2 id={titleId} class="cms-detail-modal-title" data-detail-modal-title>{title}</h2>
    <div class="cms-detail-modal-body">
      <slot />
    </div>
    <div class="cms-detail-modal-actions cms-form-actions">
      <div class="cms-form-actions-left">
        <slot name="actions-left" />
      </div>
      <div class="cms-form-actions-right">
        <slot name="actions-right" />
      </div>
    </div>
  </div>
</dialog>
