---
export const prerender = false;
import AdminLayout from './layout.astro';
import DetailModal from './components/DetailModal.astro';
import { Pencil, Trash2, Lightbulb } from '@lucide/astro';
import { loadSite, loadMenus } from '../../api/data.mjs';
const site = await loadSite();
const menusData = await loadMenus();
const menus = menusData.menus ?? [];
---

<AdminLayout site={site} title="Menús">
  <div class="cms-stack">
    <div class="cms-page-header">
      <h1 class="cms-title">Menús</h1>
      <button type="button" id="cms-menu-new-btn" class="cms-btn cms-btn-primary">Nuevo menú</button>
    </div>
    <div class="cms-card cms-menus-info-card">
      <p class="cms-menus-info-text">
        <Lightbulb size={14} class="cms-menus-info-icon" aria-hidden="true" />
        <span class="cms-menus-info-body">Cada menú se identifica por su <strong>selector</strong> (ej. <code>main</code>, <code>footer</code>). En el código del sitio se obtienen sus ítems con <code>getMenu('selector')</code> desde <code>astro-blocks/getMenu</code>; el resultado es un array de enlaces (<code>name</code>, <code>path</code>) que puedes usar en el layout o en componentes para renderizar la navegación. Los ítems pueden tener submenús anidados (<code>children</code>) para desplegables o listas anidadas.</span>
      </p>
    </div>
    <div class="cms-card cms-card--no-padding">
      <div class="cms-table-wrap">
        <table class="cms-table">
          <thead>
            <tr>
              <th class="cms-table-actions"></th>
              <th>Nombre</th>
              <th class="cms-table-cell-monospace">Selector</th>
              <th class="cms-table-actions-delete"></th>
            </tr>
          </thead>
          <tbody>
            {menus.map((m) => (
              <tr>
                <td class="cms-table-actions">
                  <button type="button" class="cms-table-btn-edit cms-menu-edit" data-id={m.id} aria-label="Editar">
                    <Pencil size={14} />
                  </button>
                </td>
                <td>{m.name}</td>
                <td class="cms-table-cell-monospace">{m.selector}</td>
                <td class="cms-table-actions-delete">
                  <button type="button" class="cms-table-btn-delete cms-menu-delete" data-id={m.id} aria-label="Eliminar">
                    <Trash2 size={14} />
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <DetailModal id="menu-detail-modal" title="Menú">
    <form id="menu-detail-form" class="cms-form">
      <input type="hidden" id="menu-detail-id" name="id" value="" />
      <div class="cms-field">
        <label for="menu-detail-name">Nombre</label>
        <input type="text" id="menu-detail-name" name="name" placeholder="Ej. Menú principal" />
      </div>
      <div class="cms-field">
        <label for="menu-detail-selector">Selector</label>
        <input type="text" id="menu-detail-selector" name="selector" placeholder="main, footer..." />
        <p id="menu-detail-selector-hint" class="cms-muted cms-hidden" style="font-size: 0.75rem; margin-top: 0.25rem;"></p>
      </div>
      <div class="cms-field">
        <label>Elementos del menú</label>
        <div class="cms-stack" style="margin-top: 0.5rem;">
          <button type="button" id="menu-detail-add-item" class="cms-btn cms-btn-secondary">Añadir elemento</button>
          <div class="cms-table-wrap">
            <table class="cms-table">
              <thead>
                <tr>
                  <th class="cms-table-actions" style="width: 2rem;"></th>
                  <th>Nombre</th>
                  <th>Ruta</th>
                  <th>Submenús</th>
                  <th class="cms-table-actions-delete"></th>
                </tr>
              </thead>
              <tbody id="menu-detail-items-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>
      <p id="menu-detail-error" class="cms-muted cms-hidden" role="alert" style="color: var(--pico-del-color); font-size: 0.75rem;"></p>
    </form>
    <button type="button" class="cms-btn cms-btn-secondary" slot="actions-left" data-close-modal="menu-detail-modal">Cancelar</button>
    <button type="button" id="menu-detail-submit" class="cms-btn cms-btn-primary" slot="actions-right">Guardar</button>
  </DetailModal>

  <script>
    import Sortable from 'sortablejs';
    // @ts-nocheck
    (function () {
      const SELECTOR_REGEX = /^[a-zA-Z0-9_-]+$/;

      function getToken() {
        try { return (typeof window !== 'undefined' && window.getCmsToken && window.getCmsToken()) || ''; } catch (e) { return ''; }
      }

      function validatePaths(items) {
        for (let i = 0; i < items.length; i++) {
          const it = items[i];
          const p = typeof it.path === 'string' ? it.path.trim() : '';
          if (!p) return 'La ruta es obligatoria en todos los elementos.';
          if (Array.isArray(it.children)) {
            const err = validatePaths(it.children);
            if (err) return err;
          }
        }
        return null;
      }

      const dialog = document.getElementById('menu-detail-modal');
      const form = document.getElementById('menu-detail-form');
      const titleEl = dialog && dialog.querySelector('[data-detail-modal-title]');
      const idInput = document.getElementById('menu-detail-id');
      const nameInput = document.getElementById('menu-detail-name');
      const selectorInput = document.getElementById('menu-detail-selector');
      const selectorHint = document.getElementById('menu-detail-selector-hint');
      const addItemBtn = document.getElementById('menu-detail-add-item');
      const tbody = document.getElementById('menu-detail-items-tbody');
      const submitBtn = document.getElementById('menu-detail-submit');
      const errorEl = document.getElementById('menu-detail-error');

      let currentMenu = { name: '', selector: '', items: [] };
      let sortableMain = null;
      const sortableChildren = [];

      function setError(msg) {
        if (errorEl) {
          errorEl.textContent = msg || '';
          errorEl.classList.toggle('cms-hidden', !msg);
        }
      }

      function setSelectorHint(valid, msg) {
        if (!selectorHint) return;
        selectorHint.textContent = msg || '';
        selectorHint.classList.toggle('cms-hidden', !msg);
        selectorHint.style.color = valid ? '' : 'var(--pico-del-color)';
      }

      function closeModal() { if (dialog) dialog.close(); }
      function openModal() { if (dialog) dialog.showModal(); }

      function destroySortables() {
        if (sortableMain) { sortableMain.destroy(); sortableMain = null; }
        sortableChildren.forEach(function (s) { if (s && s.destroy) s.destroy(); });
        sortableChildren.length = 0;
      }

      function escapeHtml(s) {
        const div = document.createElement('div');
        div.textContent = s;
        return div.innerHTML;
      }

      function renderChildRow(itemIndex, childIndex, child) {
        const name = escapeHtml(child.name ?? '');
        const path = escapeHtml(child.path ?? '');
        return (
          '<div class="menu-child-row cms-stack" data-item-index="' + itemIndex + '" data-child-index="' + childIndex + '">' +
          '<div class="cms-cluster" style="align-items: center; gap: 0.25rem;">' +
          '<span class="cms-drag-handle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg></span>' +
          '<input type="text" class="menu-child-name cms-input" placeholder="Nombre" value="' + name + '" data-field="name"/>' +
          '<input type="text" class="menu-child-path cms-input" placeholder="/ruta" value="' + path + '" data-field="path"/>' +
          '<button type="button" class="cms-table-btn-delete menu-child-delete" aria-label="Eliminar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>' +
          '</div></div>'
        );
      }

      function renderItemRow(itemIndex, item) {
        const name = escapeHtml(item.name ?? '');
        const path = escapeHtml(item.path ?? '');
        const children = Array.isArray(item.children) ? item.children : [];
        let childrenHtml = '';
        children.forEach(function (c, ci) {
          childrenHtml += renderChildRow(itemIndex, ci, c);
        });
        const childrenListId = 'menu-children-' + itemIndex;
        return (
          '<tr data-item-index="' + itemIndex + '">' +
          '<td class="cms-table-actions"><span class="cms-drag-handle" aria-hidden="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="6" r="1"/><circle cx="15" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="9" cy="18" r="1"/><circle cx="15" cy="18" r="1"/></svg></span></td>' +
          '<td><input type="text" class="cms-input menu-item-name" placeholder="Nombre" value="' + name + '" data-field="name"/></td>' +
          '<td><input type="text" class="cms-input menu-item-path" placeholder="/ruta" value="' + path + '" data-field="path"/></td>' +
          '<td><div class="menu-children-wrap">' +
          '<div class="menu-children-list" id="' + childrenListId + '">' + childrenHtml + '</div>' +
          '<button type="button" class="cms-btn cms-btn-secondary menu-add-child-btn" data-item-index="' + itemIndex + '">Añadir submenú</button></div></td>' +
          '<td class="cms-table-actions-delete"><button type="button" class="cms-table-btn-delete menu-item-delete" data-item-index="' + itemIndex + '" aria-label="Eliminar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button></td>' +
          '</tr>'
        );
      }

      function syncItemsFromDom() {
        const rows = tbody && tbody.querySelectorAll('tr[data-item-index]');
        if (!rows || !rows.length) { currentMenu.items = []; return; }
        const newItems = [];
        rows.forEach(function (tr) {
          const idx = tr.getAttribute('data-item-index');
          if (idx === null) return;
          const nameInp = tr.querySelector('.menu-item-name');
          const pathInp = tr.querySelector('.menu-item-path');
          const childrenWrap = tr.querySelector('.menu-children-list');
          const childRows = childrenWrap ? childrenWrap.querySelectorAll('.menu-child-row') : [];
          const children = [];
          childRows.forEach(function (cr) {
            const n = cr.querySelector('.menu-child-name');
            const p = cr.querySelector('.menu-child-path');
            children.push({ name: n ? n.value : '', path: p ? p.value : '' });
          });
          newItems.push({
            name: nameInp ? nameInp.value : '',
            path: pathInp ? pathInp.value : '',
            children: children.length ? children : undefined
          });
        });
        currentMenu.items = newItems;
      }

      function syncChildrenOrderFromDom(itemIndex) {
        const tr = tbody && tbody.querySelector('tr[data-item-index="' + itemIndex + '"]');
        if (!tr) return;
        const list = tr.querySelector('.menu-children-list');
        if (!list) return;
        const rows = list.querySelectorAll('.menu-child-row');
        const item = currentMenu.items[itemIndex];
        if (!item) return;
        item.children = [];
        rows.forEach(function (r) {
          const n = r.querySelector('.menu-child-name');
          const p = r.querySelector('.menu-child-path');
          item.children.push({ name: n ? n.value : '', path: p ? p.value : '' });
        });
      }

      function reRenderItems() {
        if (!tbody) return;
        destroySortables();
        tbody.innerHTML = currentMenu.items.map(function (item, i) { return renderItemRow(i, item); }).join('');

        currentMenu.items.forEach(function (_, itemIndex) {
          const tr = tbody.querySelector('tr[data-item-index="' + itemIndex + '"]');
          if (!tr) return;
          const list = tr.querySelector('.menu-children-list');
          if (list) {
            const s = Sortable.create(list, {
              handle: '.cms-drag-handle',
              ghostClass: 'cms-dragging',
              onEnd: function () { syncChildrenOrderFromDom(itemIndex); }
            });
            sortableChildren.push(s);
          }
        });

        sortableMain = Sortable.create(tbody, {
          handle: '.cms-drag-handle',
          ghostClass: 'cms-dragging',
          onEnd: function () { syncItemsFromDom(); }
        });

        tbody.querySelectorAll('.menu-item-name, .menu-item-path').forEach(function (inp) {
          inp.addEventListener('input', function () { syncItemsFromDom(); });
          inp.addEventListener('change', function () { syncItemsFromDom(); });
        });
        tbody.querySelectorAll('.menu-child-name, .menu-child-path').forEach(function (inp) {
          inp.addEventListener('input', function () {
            const row = inp.closest('.menu-child-row');
            if (row) syncChildrenOrderFromDom(parseInt(row.getAttribute('data-item-index'), 10));
          });
        });
        tbody.querySelectorAll('.menu-item-delete').forEach(function (btn) {
          btn.addEventListener('click', function () {
            const idx = parseInt(btn.getAttribute('data-item-index'), 10);
            if (isNaN(idx)) return;
            currentMenu.items.splice(idx, 1);
            reRenderItems();
          });
        });
        tbody.querySelectorAll('.menu-add-child-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            const idx = parseInt(btn.getAttribute('data-item-index'), 10);
            if (isNaN(idx)) return;
            const item = currentMenu.items[idx];
            if (!item) return;
            if (!item.children) item.children = [];
            item.children.push({ name: '', path: '' });
            reRenderItems();
          });
        });
        tbody.querySelectorAll('.menu-child-delete').forEach(function (btn) {
          btn.addEventListener('click', function () {
            const row = btn.closest('.menu-child-row');
            if (!row) return;
            const itemIndex = parseInt(row.getAttribute('data-item-index'), 10);
            const childIndex = parseInt(row.getAttribute('data-child-index'), 10);
            const item = currentMenu.items[itemIndex];
            if (item && Array.isArray(item.children)) {
              item.children.splice(childIndex, 1);
              reRenderItems();
            }
          });
        });
      }

      function openNew() {
        currentMenu = { name: '', selector: '', items: [] };
        if (idInput) idInput.value = '';
        if (nameInput) nameInput.value = '';
        if (selectorInput) selectorInput.value = '';
        setSelectorHint(false, '');
        setError('');
        reRenderItems();
        if (titleEl) titleEl.textContent = 'Nuevo menú';
        if (submitBtn) submitBtn.textContent = 'Crear';
        openModal();
      }

      function openEdit(id) {
        const token = getToken();
        fetch('/cms/api/menus', { headers: { 'Authorization': 'Bearer ' + token } })
          .then(function (r) { return r.json(); })
          .then(function (data) {
            const list = data.menus || [];
            const menu = list.find(function (m) { return m.id === id; });
            if (!menu) return;
            currentMenu = {
              name: menu.name || '',
              selector: menu.selector || '',
              items: Array.isArray(menu.items) ? JSON.parse(JSON.stringify(menu.items)) : []
            };
            if (idInput) idInput.value = menu.id;
            if (nameInput) nameInput.value = currentMenu.name;
            if (selectorInput) selectorInput.value = currentMenu.selector;
            setSelectorHint(false, '');
            setError('');
            reRenderItems();
            if (titleEl) titleEl.textContent = 'Editar menú';
            if (submitBtn) submitBtn.textContent = 'Guardar';
            openModal();
          })
          .catch(function () { setError('Error al cargar el menú.'); });
      }

      function doSubmit() {
        syncItemsFromDom();
        const name = nameInput ? nameInput.value.trim() : '';
        const selector = selectorInput ? selectorInput.value.trim() : '';
        setError('');
        if (!selector) {
          setSelectorHint(false, 'El selector es obligatorio.');
          return;
        }
        if (!SELECTOR_REGEX.test(selector)) {
          setSelectorHint(false, 'Solo letras, números, guiones y guiones bajos (sin espacios).');
          return;
        }
        setSelectorHint(true, '');
        const pathErr = validatePaths(currentMenu.items);
        if (pathErr) {
          setError(pathErr);
          return;
        }
        const token = getToken();
        const id = idInput && idInput.value ? idInput.value.trim() : '';
        const payload = { name: name || 'Menú', selector, items: currentMenu.items };
        const url = id ? '/cms/api/menus/' + encodeURIComponent(id) : '/cms/api/menus';
        const method = id ? 'PUT' : 'POST';
        fetch(url, {
          method: method,
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify(payload)
        })
          .then(function (r) {
            if (!r.ok) return r.json().then(function (err) { throw new Error(err.error || 'Error'); });
            closeModal();
            location.reload();
          })
          .catch(function (e) {
            setError(e.message || 'Error al guardar.');
          });
      }

      function deleteMenu(id) {
        window.cmsConfirm({ message: '¿Eliminar este menú?', confirmLabel: 'Eliminar' }).then(function (ok) {
          if (!ok) return;
          const token = getToken();
          fetch('/cms/api/menus/' + encodeURIComponent(id), { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token } })
            .then(function (r) {
              if (r.status === 204) { location.reload(); return; }
              throw new Error('Error al eliminar');
            })
            .catch(function () { window.cmsAlert({ message: 'Error al eliminar', title: 'Error' }); });
        });
      }

      if (selectorInput) {
        selectorInput.addEventListener('input', function () {
          const v = selectorInput.value.trim();
          if (!v) { setSelectorHint(false, ''); return; }
          setSelectorHint(SELECTOR_REGEX.test(v), SELECTOR_REGEX.test(v) ? '' : 'Solo letras, números, guiones y guiones bajos (sin espacios).');
        });
      }
      if (addItemBtn) {
        addItemBtn.addEventListener('click', function () {
          currentMenu.items.push({ name: '', path: '' });
          reRenderItems();
        });
      }
      if (submitBtn) submitBtn.addEventListener('click', doSubmit);
      document.getElementById('cms-menu-new-btn')?.addEventListener('click', openNew);
      document.querySelectorAll('.cms-menu-edit').forEach(function (btn) {
        btn.addEventListener('click', function () { openEdit(btn.getAttribute('data-id')); });
      });
      document.querySelectorAll('.cms-menu-delete').forEach(function (btn) {
        btn.addEventListener('click', function () { deleteMenu(btn.getAttribute('data-id')); });
      });
      dialog?.addEventListener('click', function (e) {
        if (e.target && e.target.getAttribute && e.target.getAttribute('data-close-modal') === 'menu-detail-modal') closeModal();
        if (e.target === dialog) closeModal();
      });
      dialog?.addEventListener('cancel', closeModal);
    })();
  </script>
</AdminLayout>
