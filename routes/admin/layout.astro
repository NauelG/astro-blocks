import { Image } from 'astro:assets';
import '@picocss/pico/css/pico.min.css';
import 'animate.css';
import '../../styles/cms-admin.css';
import { LayoutDashboard, FileText, Menu, Settings, RefreshCw, User, LogOut, Users, ExternalLink, Languages } from '@lucide/astro';
import ConfirmDialog from './components/ConfirmDialog.astro';
import AlertDialog from './components/AlertDialog.astro';
import pkg from '../../package.json' with { type: 'json' };
import blocksLogo from '../../img/blocks_logo.jpg';
import faviconUrl from '../../img/favicon.ico?url';
const { site = {}, title = 'AstroBlocks' } = Astro.props;
const cmsVersion = pkg.version;
const primary = site.primaryColor || '#333';
const secondary = site.secondaryColor || site.primaryColor || '#666';
const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/cms') return currentPath === '/cms' || currentPath === '/cms/';
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="en" data-theme="light" style="color-scheme: light;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href={faviconUrl} type="image/x-icon" />
    <title>{title}</title>
  </head>
  <body class="cms-root" style={`--cms-primary: ${primary}; --cms-secondary: ${secondary};`}>
    <div id="admin-wrap" class="cms-wrap">
      <div id="login-form" class="cms-hidden cms-login-wrap">
        <div class="cms-login-card cms-card cms-animate-in">
          <div id="cms-auth-logo" class="cms-auth-logo"></div>
          <p id="cms-auth-loading" class="cms-muted">Cargando…</p>
          <div id="cms-auth-forms" class="cms-hidden">
            <p id="cms-auth-message" class="cms-muted"></p>
            <form id="cms-login-form" class="cms-login-fields" method="post" action="#" autocomplete="off">
              <input
                type="email"
                id="cms-email-input"
                name="email"
                placeholder="Email"
                class="cms-input"
                autocomplete="username"
              />
              <input
                type="password"
                id="cms-password-input"
                name="password"
                placeholder="Contraseña"
                class="cms-input"
                autocomplete="current-password"
              />
              <button type="submit" id="cms-login-btn" class="cms-btn cms-btn-primary">
                <span id="cms-submit-label">Entrar</span>
              </button>
            </form>
          </div>
          <p id="cms-login-error" class="cms-muted cms-hidden" role="alert"></p>
        </div>
      </div>
      <div id="admin-content" class="cms-hidden cms-panel">
        <header class="cms-topbar" role="banner">
          <div class="cms-topbar-shell">
            <div class="cms-topbar-context">
              <button
                type="button"
                class="cms-topbar-nav-toggle"
                id="cms-sidebar-toggle"
                aria-label="Abrir navegación"
                aria-expanded="false"
                aria-controls="cms-sidebar"
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" fill="none">
                  <path d="M4 7h16" />
                  <path d="M4 12h16" />
                  <path d="M4 17h16" />
                </svg>
              </button>
              <div class="cms-topbar-brand">
                <div class="cms-topbar-heading-row">
                  <span class="cms-topbar-title">{title}</span>
                  {site.siteName && <span class="cms-topbar-site-pill">{site.siteName}</span>}
                </div>
              </div>
            </div>
            <div class="cms-topbar-actions">
              <div class="cms-topbar-locale">
                <label for="cms-content-locale-select" class="cms-hidden">Idioma de contenido</label>
                <select id="cms-content-locale-select" aria-label="Idioma de contenido">
                  <option value="">Cargando…</option>
                </select>
              </div>
              {site.baseUrl && (
                <a href={site.baseUrl} target="_blank" rel="noopener noreferrer" class="cms-btn cms-btn-secondary cms-topbar-site-link">
                  <ExternalLink size={13} />
                  <span>Ver sitio</span>
                </a>
              )}
            </div>
            <div class="cms-topbar-profile">
              <button type="button" class="cms-topbar-profile-trigger" id="cms-profile-trigger" aria-haspopup="true" aria-expanded="false" aria-label="Menú de usuario">
                <User class="cms-topbar-profile-icon" size={14} />
              </button>
            </div>
          </div>
        </header>
        <div class="cms-panel-body">
          <button type="button" class="cms-sidebar-overlay" id="cms-sidebar-overlay" aria-hidden="true" tabindex="-1"></button>
          <aside class="cms-sidebar" id="cms-sidebar">
            <div class="cms-sidebar-brand">
              <Image src={blocksLogo} width={32} height={32} alt="" class="cms-sidebar-brand-logo" />
              <div class="cms-sidebar-brand-copy">
                <span class="cms-sidebar-brand-eyebrow">Content platform</span>
              </div>
            </div>
            <nav class="cms-nav" aria-label="Panel">
              <a href="/cms" class={`cms-nav-link ${isActive('/cms') ? 'cms-nav-link--active' : ''}`}>
                <LayoutDashboard class="cms-nav-icon" size={16} />
                <span>Dashboard</span>
              </a>
              <div class="cms-nav-group">
                <span class="cms-nav-group-title">Contenido</span>
                <a href="/cms/pages" class={`cms-nav-link ${isActive('/cms/pages') ? 'cms-nav-link--active' : ''}`}>
                  <FileText class="cms-nav-icon" size={16} />
                  <span>Páginas</span>
                </a>
                <a href="/cms/menus" class={`cms-nav-link ${isActive('/cms/menus') ? 'cms-nav-link--active' : ''}`}>
                  <Menu class="cms-nav-icon" size={16} />
                  <span>Menús</span>
                </a>
              </div>
              <div class="cms-nav-group">
                <span class="cms-nav-group-title">Configuración</span>
                <a href="/cms/settings" class={`cms-nav-link ${isActive('/cms/settings') ? 'cms-nav-link--active' : ''}`} data-cms-owner-only>
                  <Settings class="cms-nav-icon" size={16} />
                  <span>Ajustes</span>
                </a>
                <a href="/cms/users" class={`cms-nav-link ${isActive('/cms/users') ? 'cms-nav-link--active' : ''}`} data-cms-owner-only>
                  <Users class="cms-nav-icon" size={16} />
                  <span>Usuarios</span>
                </a>
                <a href="/cms/languages" class={`cms-nav-link ${isActive('/cms/languages') ? 'cms-nav-link--active' : ''}`} data-cms-owner-only>
                  <Languages class="cms-nav-icon" size={16} />
                  <span>Idiomas</span>
                </a>
                <a href="/cms/cache" class={`cms-nav-link ${isActive('/cms/cache') ? 'cms-nav-link--active' : ''}`}>
                  <RefreshCw class="cms-nav-icon" size={16} />
                  <span>Caché</span>
                </a>
              </div>
            </nav>
          </aside>
          <main class="cms-main cms-animate-in">
            <slot />
          </main>
        </div>
        <footer class="cms-footer" role="contentinfo">
          <Image src={blocksLogo} width={12} height={12} alt="" class="cms-footer-logo" />
          <span class="cms-footer-name">AstroBlocks CMS</span>
          <span class="cms-footer-version">v{cmsVersion}</span>
        </footer>
      </div>
    </div>
    <ConfirmDialog />
    <AlertDialog />
    <div class="cms-topbar-dropdown" id="cms-profile-dropdown" role="menu">
      <div class="cms-topbar-dropdown-label">
        <span class="cms-topbar-dropdown-label-title">{site.siteName || 'AstroBlocks'}</span>
        <span class="cms-topbar-dropdown-label-text" id="cms-profile-email">Sesión del panel</span>
      </div>
      <div class="cms-topbar-dropdown-divider"></div>
      <div class="cms-field" style="padding: 0 0.75rem 0.5rem;">
        <label for="cms-ui-locale-select" style="font-size: 0.6875rem; margin-bottom: 0.25rem;">Idioma del panel</label>
        <select id="cms-ui-locale-select" aria-label="Idioma del panel">
          <option value="es">Español</option>
        </select>
      </div>
      <div class="cms-topbar-dropdown-divider"></div>
      <button type="button" class="cms-topbar-dropdown-item" id="cms-logout-btn" data-profile-action="logout" role="menuitem">
        <LogOut class="cms-topbar-dropdown-icon" size={14} />
        <span>Salir</span>
      </button>
    </div>
    <div id="cms-toast-region" class="cms-toast-region" aria-live="polite" aria-atomic="true"></div>
    <script>
      (function() {
        if (typeof document === 'undefined') return;
        const loginForm = document.getElementById('login-form');
        const adminContent = document.getElementById('admin-content');
        const authLogo = document.getElementById('cms-auth-logo');
        const authLoading = document.getElementById('cms-auth-loading');
        const authForms = document.getElementById('cms-auth-forms');
        const authMessage = document.getElementById('cms-auth-message');
        const submitLabel = document.getElementById('cms-submit-label');
        const loginFormEl = document.getElementById('cms-login-form');
        const emailInput = document.getElementById('cms-email-input');
        const passwordInput = document.getElementById('cms-password-input');
        const loginError = document.getElementById('cms-login-error');
        const profileEmail = document.getElementById('cms-profile-email');
        function setProfileEmail(user: { email?: string; role?: string } | null) {
          if (!profileEmail) return;
          if (!user?.email) {
            profileEmail.textContent = 'Sesión del panel';
            return;
          }
          profileEmail.textContent = user.role === 'owner' ? `${user.email} · Owner` : user.email;
        }
        function show(hasToken: boolean) {
          if (loginForm) loginForm.classList.toggle('cms-hidden', hasToken);
          if (adminContent) adminContent.classList.toggle('cms-hidden', !hasToken);
        }
        function setLoginError(msg: string) {
          if (loginError) {
            loginError.textContent = msg;
            loginError.classList.toggle('cms-hidden', !msg);
          }
        }
        function setAuthScreen(hasUsers: boolean, logo: string, siteName: string) {
          if (authLogo) {
            if (logo) {
              const img = document.createElement('img');
              img.src = logo;
              img.alt = siteName;
              img.className = 'cms-auth-logo-img';
              authLogo.innerHTML = '';
              authLogo.appendChild(img);
            } else {
              authLogo.innerHTML = '<span class="cms-auth-logo-title">' + (siteName || 'AstroBlocks') + '</span>';
            }
          }
          if (authMessage) {
            authMessage.textContent = hasUsers
              ? 'Inicia sesión con tu email y contraseña.'
              : 'Crea la cuenta del primer usuario (propietario).';
          }
          if (submitLabel) submitLabel.textContent = hasUsers ? 'Entrar' : 'Crear cuenta';
          if (authLoading) authLoading.classList.add('cms-hidden');
          if (authForms) authForms.classList.remove('cms-hidden');
        }
        try {
          const token = sessionStorage.getItem('cms-token');
          show(!!token);
          if (token && adminContent && !adminContent.classList.contains('cms-hidden')) {
            fetch('/cms/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } })
              .then((r) => r.ok ? r.json() : null)
              .then((data) => {
                if (data?.user) {
                  try { sessionStorage.setItem('cms-user', JSON.stringify(data.user)); } catch (_) {}
                  setProfileEmail(data.user);
                }
                document.querySelectorAll('[data-cms-owner-only]').forEach((el) => {
                  (el as HTMLElement).style.display = data?.user?.role === 'owner' ? '' : 'none';
                });
              })
              .catch(() => {});
          } else if (token) {
            const raw = sessionStorage.getItem('cms-user');
            const user = raw ? (() => { try { return JSON.parse(raw); } catch { return null; } })() : null;
            setProfileEmail(user);
            document.querySelectorAll('[data-cms-owner-only]').forEach((el) => {
              (el as HTMLElement).style.display = user?.role === 'owner' ? '' : 'none';
            });
          } else {
            setProfileEmail(null);
            fetch('/cms/api/auth/status')
              .then((r) => r.ok ? r.json() : { hasUsers: true, logo: '', siteName: 'CMS' })
              .then((data) => setAuthScreen(!!data.hasUsers, data.logo || '', data.siteName || 'AstroBlocks'))
              .catch(() => setAuthScreen(true, '', 'AstroBlocks'));
          }
        } catch (e) {}
        if (loginFormEl && emailInput && passwordInput) {
          loginFormEl.addEventListener('submit', async function(e) {
            e.preventDefault();
            const email = (emailInput as HTMLInputElement).value.trim();
            const password = (passwordInput as HTMLInputElement).value;
            setLoginError('');
            if (!email || !password) {
              setLoginError('Email y contraseña obligatorios.');
              return;
            }
            const res = await fetch('/cms/api/auth/login', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email, password }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
              setLoginError(data.error || 'Error al iniciar sesión.');
              return;
            }
            try {
              sessionStorage.setItem('cms-token', data.token);
              if (data.user) sessionStorage.setItem('cms-user', JSON.stringify(data.user));
            } catch (_) {}
            location.reload();
          });
        }
      })();
    </script>
    <script>
      (window as unknown as {
        getCmsToken: () => string;
        getCmsUser: () => { id: string; email: string; role: string } | null;
        getCmsContentLocale: () => string;
        setCmsContentLocale: (locale: string) => void;
      }).getCmsToken = function() {
        try { return sessionStorage.getItem('cms-token') || ''; } catch (e) { return ''; }
      };
      (window as unknown as { getCmsUser: () => { id: string; email: string; role: string } | null }).getCmsUser = function() {
        try {
          const raw = sessionStorage.getItem('cms-user');
          return raw ? JSON.parse(raw) : null;
        } catch (e) { return null; }
      };
      (window as unknown as { getCmsContentLocale: () => string }).getCmsContentLocale = function() {
        try { return sessionStorage.getItem('cms-content-locale') || ''; } catch (e) { return ''; }
      };
      (window as unknown as { setCmsContentLocale: (locale: string) => void }).setCmsContentLocale = function(locale: string) {
        try { sessionStorage.setItem('cms-content-locale', locale); } catch (e) {}
      };
      (function() {
        if (typeof document === 'undefined') return;

        const UI_LOCALES = [{ code: 'es', label: 'Español' }];
        const cmsWindow = window as unknown as {
          getCmsToken?: () => string;
          setCmsContentLocale?: (locale: string) => void;
          refreshCmsContentLocaleSelector?: () => Promise<void>;
        };

        function initUiLocaleSelector() {
          const select = document.getElementById('cms-ui-locale-select') as HTMLSelectElement | null;
          if (!select) return;

          const allowed = new Set(UI_LOCALES.map((entry) => entry.code));
          const stored = (() => { try { return sessionStorage.getItem('cms-ui-locale') || ''; } catch (_) { return ''; } })();
          const selected = allowed.has(stored) ? stored : UI_LOCALES[0].code;

          select.innerHTML = UI_LOCALES.map((entry) => `<option value="${entry.code}">${entry.label}</option>`).join('');
          select.value = selected;
          try { sessionStorage.setItem('cms-ui-locale', selected); } catch (_) {}

          select.addEventListener('change', () => {
            const next = select.value;
            if (!allowed.has(next)) return;
            try { sessionStorage.setItem('cms-ui-locale', next); } catch (_) {}
          });
        }

        async function initContentLocaleSelector() {
          const select = document.getElementById('cms-content-locale-select') as HTMLSelectElement | null;
          if (!select) return;

          const token = cmsWindow.getCmsToken?.() || '';
          if (!token) {
            select.innerHTML = '<option value="">—</option>';
            select.disabled = true;
            select.onchange = null;
            return;
          }

          try {
            const response = await fetch('/cms/api/languages', {
              headers: { Authorization: 'Bearer ' + token },
            });
            if (!response.ok) throw new Error('Failed to load languages');
            const payload = await response.json();
            const languages = (payload.languages || []).filter((entry: { enabled?: boolean }) => entry.enabled !== false);
            if (!Array.isArray(languages) || languages.length === 0) {
              select.innerHTML = '<option value="">—</option>';
              select.disabled = true;
              return;
            }

            const defaultLanguage =
              languages.find((entry: { isDefault?: boolean }) => entry.isDefault) ||
              languages[0];

            const stored = (() => { try { return sessionStorage.getItem('cms-content-locale') || ''; } catch (_) { return ''; } })();
            const availableCodes = new Set(languages.map((entry: { code: string }) => entry.code));
            const selected = availableCodes.has(stored) ? stored : defaultLanguage.code;

            select.innerHTML = languages
              .map((entry: { code: string; label?: string }) => `<option value="${entry.code}">${entry.label || entry.code}</option>`)
              .join('');
            select.value = selected;
            select.disabled = false;
            cmsWindow.setCmsContentLocale?.(selected);

            select.onchange = () => {
              const next = select.value;
              if (!availableCodes.has(next)) return;
              try { sessionStorage.setItem('cms-content-locale', next); } catch (_) {}
              cmsWindow.setCmsContentLocale?.(next);
              window.dispatchEvent(new CustomEvent('cms:content-locale-change', { detail: { locale: next } }));
            };
          } catch {
            select.innerHTML = '<option value="">—</option>';
            select.disabled = true;
            select.onchange = null;
          }
        }

        cmsWindow.refreshCmsContentLocaleSelector = initContentLocaleSelector;
        window.addEventListener('cms:languages-updated', () => {
          void initContentLocaleSelector();
        });

        const run = () => {
          initUiLocaleSelector();
          void initContentLocaleSelector();
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
    </script>
    <script>
      (function() {
        if (typeof document === 'undefined') return;

        type ManagedSelect = {
          select: HTMLSelectElement;
          shell: HTMLDivElement;
          trigger: HTMLButtonElement;
          label: HTMLSpanElement;
          menu: HTMLDivElement;
          observer: MutationObserver;
          closeMenu: () => void;
          syncFromSelect: () => void;
          lastValue: string;
          lastSignature: string;
          lastDisabled: boolean;
        };

        const managed = new Map<HTMLSelectElement, ManagedSelect>();
        let openSelect: ManagedSelect | null = null;

        function getOptionSignature(select: HTMLSelectElement): string {
          return Array.from(select.options)
            .map((option) => `${option.value}\u0001${option.textContent || ''}\u0001${option.disabled ? '1' : '0'}`)
            .join('\u0002');
        }

        function setTriggerLabel(entry: ManagedSelect): void {
          const selected = entry.select.options[entry.select.selectedIndex] || entry.select.options[0];
          entry.label.textContent = selected?.textContent?.trim() || 'Seleccionar';
        }

        function syncActiveOption(entry: ManagedSelect): void {
          const selectedValue = entry.select.value;
          entry.menu.querySelectorAll('.cms-select-option').forEach((node) => {
            const item = node as HTMLButtonElement;
            const active = item.dataset.value === selectedValue;
            item.classList.toggle('cms-select-option--active', active);
            item.setAttribute('aria-selected', active ? 'true' : 'false');
          });
        }

        function closeMenu(entry: ManagedSelect): void {
          entry.shell.classList.remove('cms-select--open');
          entry.trigger.setAttribute('aria-expanded', 'false');
          if (openSelect === entry) openSelect = null;
        }

        function openMenu(entry: ManagedSelect): void {
          if (entry.select.disabled) return;
          if (openSelect && openSelect !== entry) closeMenu(openSelect);
          entry.shell.classList.add('cms-select--open');
          entry.trigger.setAttribute('aria-expanded', 'true');
          openSelect = entry;
        }

        function renderOptions(entry: ManagedSelect): void {
          entry.menu.innerHTML = '';

          Array.from(entry.select.options).forEach((option) => {
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'cms-select-option';
            item.dataset.value = option.value;
            item.role = 'option';
            item.disabled = option.disabled;
            item.textContent = option.textContent || option.value;

            item.addEventListener('click', (event) => {
              event.preventDefault();
              if (option.disabled) return;
              entry.select.value = option.value;
              entry.select.dispatchEvent(new Event('change', { bubbles: true }));
              closeMenu(entry);
            });

            entry.menu.appendChild(item);
          });

          setTriggerLabel(entry);
          syncActiveOption(entry);
          entry.trigger.disabled = entry.select.disabled;
          entry.shell.classList.toggle('cms-select--disabled', entry.select.disabled);
          entry.lastValue = entry.select.value;
          entry.lastSignature = getOptionSignature(entry.select);
          entry.lastDisabled = entry.select.disabled;
        }

        function syncFromSelect(entry: ManagedSelect): void {
          const nextSignature = getOptionSignature(entry.select);
          const nextValue = entry.select.value;
          const nextDisabled = entry.select.disabled;

          if (nextSignature !== entry.lastSignature || nextDisabled !== entry.lastDisabled) {
            renderOptions(entry);
            return;
          }

          if (nextValue !== entry.lastValue) {
            entry.lastValue = nextValue;
            setTriggerLabel(entry);
            syncActiveOption(entry);
          }
        }

        function enhanceSelect(select: HTMLSelectElement): void {
          if (!select || select.dataset.cmsSelectEnhanced === 'true') return;
          if (select.multiple || Number(select.size || 1) > 1) return;
          if (!select.parentElement) return;

          const shell = document.createElement('div');
          shell.className = 'cms-select';

          select.parentElement.insertBefore(shell, select);
          shell.appendChild(select);
          select.classList.add('cms-select-native');
          select.dataset.cmsSelectEnhanced = 'true';

          const trigger = document.createElement('button');
          trigger.type = 'button';
          trigger.className = 'cms-select-trigger';
          trigger.setAttribute('aria-haspopup', 'listbox');
          trigger.setAttribute('aria-expanded', 'false');

          const label = document.createElement('span');
          label.className = 'cms-select-trigger-label';

          const caret = document.createElement('span');
          caret.className = 'cms-select-trigger-caret';
          caret.innerHTML = '<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M4.25 6.25L8 10l3.75-3.75" /></svg>';

          trigger.appendChild(label);
          trigger.appendChild(caret);

          const menu = document.createElement('div');
          menu.className = 'cms-select-menu';
          menu.role = 'listbox';

          shell.appendChild(trigger);
          shell.appendChild(menu);

          const entry: ManagedSelect = {
            select,
            shell,
            trigger,
            label,
            menu,
            observer: new MutationObserver(() => {}),
            closeMenu: () => closeMenu(entry),
            syncFromSelect: () => syncFromSelect(entry),
            lastValue: select.value,
            lastSignature: '',
            lastDisabled: select.disabled,
          };

          trigger.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            if (shell.classList.contains('cms-select--open')) closeMenu(entry);
            else openMenu(entry);
          });

          select.addEventListener('change', () => {
            syncFromSelect(entry);
          });

          entry.observer = new MutationObserver(() => {
            renderOptions(entry);
          });
          entry.observer.observe(select, {
            childList: true,
            subtree: true,
            attributes: true,
            attributeFilter: ['disabled', 'label'],
          });

          renderOptions(entry);
          managed.set(select, entry);
        }

        function enhanceSelects(root: ParentNode = document): void {
          if (!(root instanceof Element || root instanceof Document || root instanceof DocumentFragment)) return;

          if (root instanceof HTMLSelectElement) {
            enhanceSelect(root);
            return;
          }

          if (root instanceof Element && root.matches('select')) {
            enhanceSelect(root as HTMLSelectElement);
          }

          root.querySelectorAll('select').forEach((node) => enhanceSelect(node as HTMLSelectElement));
        }

        function closeOpenIfOutside(target: EventTarget | null): void {
          if (!openSelect || !(target instanceof Node)) return;
          if (openSelect.shell.contains(target)) return;
          closeMenu(openSelect);
        }

        function cleanupDisconnected(): void {
          for (const [select, entry] of managed.entries()) {
            if (document.contains(select)) continue;
            if (openSelect === entry) openSelect = null;
            entry.observer.disconnect();
            managed.delete(select);
          }
        }

        (window as unknown as { initCmsSelects?: (root?: ParentNode) => void }).initCmsSelects = enhanceSelects;

        document.addEventListener('click', (event) => closeOpenIfOutside(event.target));
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && openSelect) closeMenu(openSelect);
        });

        window.addEventListener('resize', () => {
          if (openSelect) closeMenu(openSelect);
        });
        window.addEventListener('scroll', () => {
          if (openSelect) closeMenu(openSelect);
        }, true);

        const mountObserver = new MutationObserver((records) => {
          for (const record of records) {
            for (const node of Array.from(record.addedNodes)) {
              if (!(node instanceof Element)) continue;
              enhanceSelects(node);
            }
          }
        });

        const start = () => {
          enhanceSelects(document);
          if (document.body) {
            mountObserver.observe(document.body, { childList: true, subtree: true });
          }

          window.setInterval(() => {
            cleanupDisconnected();
            managed.forEach((entry) => entry.syncFromSelect());
          }, 220);
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', start, { once: true });
        } else {
          start();
        }
      })();
    </script>
    <script>
      (function() {
        if (typeof document === 'undefined') return;
        const toastRegion = document.getElementById('cms-toast-region');
        let toastTimer = 0;
        (window as unknown as {
          cmsToast?: (options: { title?: string; message: string; tone?: 'success' | 'error' | 'info' }) => void;
        }).cmsToast = function(options) {
          if (!toastRegion || !options?.message) return;
          toastRegion.innerHTML = '';
          const toast = document.createElement('div');
          toast.className = `cms-toast cms-toast--${options.tone || 'info'}`;
          toast.innerHTML =
            `<strong class="cms-toast-title">${options.title || 'Aviso'}</strong>` +
            `<p class="cms-toast-message"></p>`;
          const messageEl = toast.querySelector('.cms-toast-message');
          if (messageEl) messageEl.textContent = options.message;
          toastRegion.appendChild(toast);
          requestAnimationFrame(() => toast.classList.add('cms-toast--visible'));
          window.clearTimeout(toastTimer);
          toastTimer = window.setTimeout(function() {
            toast.classList.remove('cms-toast--visible');
            window.setTimeout(function() {
              if (toast.parentElement === toastRegion) toast.remove();
            }, 180);
          }, 2800);
        };
        function initProfileDropdown() {
          const trigger = document.getElementById('cms-profile-trigger');
          const dropdown = document.getElementById('cms-profile-dropdown');
          const sidebar = document.getElementById('cms-sidebar');
          const overlay = document.getElementById('cms-sidebar-overlay');
          const sidebarToggle = document.getElementById('cms-sidebar-toggle');
          if (!trigger || !dropdown) return;
          const triggerEl = trigger;
          const dropdownEl = dropdown;
          const sidebarEl = sidebar;
          const overlayEl = overlay;
          const sidebarToggleEl = sidebarToggle;
          function updateDropdownPosition() {
            const rect = triggerEl.getBoundingClientRect();
            dropdownEl.style.top = Math.round(rect.bottom + 10) + 'px';
            dropdownEl.style.left = Math.round(rect.right - dropdownEl.offsetWidth) + 'px';
          }
          function isOpen() {
            return dropdownEl.classList.contains('cms-topbar-dropdown--open');
          }
          function open() {
            updateDropdownPosition();
            dropdownEl.classList.add('cms-topbar-dropdown--open');
            triggerEl.setAttribute('aria-expanded', 'true');
          }
          function close() {
            dropdownEl.classList.remove('cms-topbar-dropdown--open');
            triggerEl.setAttribute('aria-expanded', 'false');
          }
          function openSidebar() {
            if (!sidebarEl || !overlayEl || !sidebarToggleEl) return;
            sidebarEl.classList.add('cms-sidebar--open');
            overlayEl.classList.add('cms-sidebar-overlay--visible');
            sidebarToggleEl.setAttribute('aria-expanded', 'true');
            document.body.classList.add('cms-sidebar-open');
          }
          function closeSidebar() {
            if (!sidebarEl || !overlayEl || !sidebarToggleEl) return;
            sidebarEl.classList.remove('cms-sidebar--open');
            overlayEl.classList.remove('cms-sidebar-overlay--visible');
            sidebarToggleEl.setAttribute('aria-expanded', 'false');
            document.body.classList.remove('cms-sidebar-open');
          }
          function toggle(e: Event) {
            e.preventDefault();
            e.stopPropagation();
            if (isOpen()) close(); else open();
          }
          triggerEl.addEventListener('click', toggle);
          dropdownEl.addEventListener('click', function(e) {
            const origin = e.target instanceof Element ? e.target : null;
            const target = origin ? origin.closest('[data-profile-action]') : null;
            if (target instanceof Element) {
              const action = target.getAttribute('data-profile-action');
              if (action === 'logout') {
                e.preventDefault();
                e.stopPropagation();
                close();
                try { sessionStorage.removeItem('cms-token'); sessionStorage.removeItem('cms-user'); } catch (err) {}
                location.href = '/cms';
                return;
              }
            }
            e.stopPropagation();
          });
          document.addEventListener('click', function(e: MouseEvent) {
            const target = e.target instanceof Node ? e.target : null;
            if (!isOpen() || !target) return;
            if (!dropdownEl.contains(target) && !triggerEl.contains(target)) close();
          });
          sidebarToggleEl?.addEventListener('click', function() {
            if (sidebarEl?.classList.contains('cms-sidebar--open')) closeSidebar();
            else openSidebar();
          });
          overlayEl?.addEventListener('click', closeSidebar);
          window.addEventListener('resize', function() {
            if (isOpen()) updateDropdownPosition();
            if (window.innerWidth > 980) closeSidebar();
          });
          window.addEventListener('scroll', function() {
            if (isOpen()) updateDropdownPosition();
          }, true);
          document.addEventListener('keydown', function(e: KeyboardEvent) {
            if (e.key === 'Escape' && isOpen()) close();
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initProfileDropdown);
        } else {
          initProfileDropdown();
        }
      })();
    </script>
  </body>
</html>
