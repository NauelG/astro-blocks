export const prerender = false;
import AdminLayout from './layout.astro';
import { loadSite } from '../../api/data.mjs';
const site = await loadSite();
---

<AdminLayout site={site} title="Regenerar sitio">
  <div class="cms-stack">
    <div class="cms-page-header">
      <h1 class="cms-title">Regenerar sitio</h1>
    </div>
    <div class="cms-info-callout">
      <div class="cms-info-callout-body">
        <p class="cms-info-callout-title">¿Cuándo usar esta acción?</p>
        <p>
          Al regenerar el sitio se vuelven a generar todas las páginas HTML, recursos estáticos y metadatos (sitemap, etc.) con el contenido y la configuración actuales. Es equivalente a ejecutar un build completo del proyecto (por ejemplo <code class="cms-code">npm run build</code>).
        </p>
        <p>
          Úsalo cuando hayas guardado cambios en páginas, menús o ajustes y quieras que el sitio público refleje esas actualizaciones. La operación puede tardar unos segundos.
        </p>
      </div>
    </div>
    <div class="cms-card">
      <div class="cms-rebuild-action">
        <button type="button" id="rebuild-confirm-btn" class="cms-btn cms-btn-primary">Regenerar sitio</button>
      </div>
    </div>
  </div>
  <script>
    (function() {
      const btn = document.getElementById('rebuild-confirm-btn');
      if (!btn) return;
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        const token = (typeof window !== 'undefined' && window.getCmsToken) ? window.getCmsToken() : '';
        try {
          const res = await fetch('/cms/api/rebuild', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token } });
          if (res.ok) await window.cmsAlert({ message: 'Build iniciado.', title: 'Regenerar sitio' });
          else await window.cmsAlert({ message: 'Error: ' + (await res.text()), title: 'Error' });
        } finally {
          btn.disabled = false;
        }
      });
    })();
  </script>
</AdminLayout>
