{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "lib": ["ES2023", "DOM"],
    "types": ["node"]
  },
  "include": [
    "plugin/**/*.ts",
    "api/**/*.ts",
    "contract/**/*.ts",
    "utils/**/*.ts",
    "routes/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "playgrounds",
    "tests"
  ]
}
