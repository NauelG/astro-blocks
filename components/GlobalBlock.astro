import { loadGlobalBlocks, loadLanguages, getDefaultLocale } from '../api/data.js';
import { localizeBlockPropsForRender } from '../utils/block-props.js';
import { normalizeLocaleCode } from '../utils/localization.js';
import { pathToSlug, resolveLocalizedSlug } from '../utils/slug.js';
import { componentMap, globalBlocksRegistry, schemaMap as runtimeSchemaMap } from 'astro-blocks-runtime';

interface Props {
  slug: string;
}

const { slug } = Astro.props;

// Look up the declared registry entry for this slug
const decl = globalBlocksRegistry.find((e: { slug: string }) => e.slug === slug);

if (!decl) {
  if (import.meta.env.DEV) {
    console.warn(
      `[astro-blocks] <GlobalBlock slug="${slug}" /> — slug is not declared in globalBlocks config. ` +
      `Add { slug: "${slug}", schema: yourSchema } to globalBlocks in astro.config.mjs.`
    );
  }
}

let resolvedProps: Record<string, unknown> = {};
let Component: unknown = null;

if (decl) {
  const [globalBlocksData, languagesData] = await Promise.all([
    loadGlobalBlocks(),
    loadLanguages(),
  ]);

  const defaultLocale = getDefaultLocale(languagesData);
  const enabledLocales = (languagesData.languages || [])
    .filter((lang: { enabled?: boolean }) => lang.enabled !== false)
    .map((lang: { code: string }) => normalizeLocaleCode(lang.code))
    .filter(Boolean);
  // astro-blocks manages its own prefix routing (see page.astro). Astro.currentLocale is only
  // populated when the consumer configures `i18n` in astro.config.mjs, which astro-blocks does
  // not require. Fall back to resolving the locale from the URL path prefix.
  const urlLocale = resolveLocalizedSlug(
    pathToSlug(new URL(Astro.request.url).pathname),
    enabledLocales,
    defaultLocale
  ).locale;
  const locale = normalizeLocaleCode(Astro.currentLocale ?? urlLocale) || defaultLocale;
  const localeKeys = new Set(enabledLocales);

  const entry = globalBlocksData.globalBlocks[slug];
  // SCEN-16: no stored entry → render with {} (no warn, no skip)
  const rawProps: Record<string, unknown> = entry?.props ?? {};

  resolvedProps = localizeBlockPropsForRender(rawProps, decl.schemaName, runtimeSchemaMap, locale, defaultLocale, localeKeys);
  Component = componentMap[decl.schemaName] ?? null;
}
---

{decl && Component ? <Component {...resolvedProps} /> : null}
